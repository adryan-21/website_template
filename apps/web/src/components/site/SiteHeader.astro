---
import type { CmsLink } from '@website-template/cms-sdk';
import {
  buttonBaseClass,
  localeLinkActiveClass,
  localeLinkClass,
  navLinkActiveClass,
  navLinkClass,
} from '@website-template/ui';
import { localizeHref, type LocaleSwitchLink, type SiteLocale } from '@/lib/site';

interface Props {
  siteName: string;
  links: CmsLink[];
  currentPath: string;
  locale: SiteLocale;
  homeHref: string;
  localeSwitchLinks: LocaleSwitchLink[];
  cta?: CmsLink;
}

const { siteName, links, currentPath, locale, homeHref, localeSwitchLinks, cta } = Astro.props;

const normalizePath = (href: string) => (href === '/' ? href : href.replace(/\/$/, ''));
const current = normalizePath(currentPath);
const brandMark = siteName
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((chunk) => chunk[0]?.toUpperCase() ?? '')
  .join('');

const shellClass =
  'mx-auto flex max-w-7xl flex-col gap-4 border-b border-zinc-900/10 px-4 py-4 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8';
const brandClass =
  'inline-flex items-center gap-3 text-sm font-semibold tracking-tight text-zinc-950 no-underline';
const brandMarkClass =
  'inline-grid h-9 w-9 place-items-center rounded-xl border border-zinc-900/15 bg-white/70 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-zinc-950';
const navClass = 'flex flex-wrap gap-2 md:justify-center';
const ctaClass = `${buttonBaseClass} border-zinc-900/20 bg-white/70 text-zinc-950 hover:border-zinc-900/30 hover:bg-white`;
---

<header class={shellClass}>
  <a class={brandClass} href={homeHref}>
    <span class={brandMarkClass} aria-hidden="true">{brandMark}</span>
    <span>{siteName}</span>
  </a>

  {
    links.length > 0 && (
      <div class="flex flex-col gap-3 md:flex-1 md:items-center">
        <nav class={navClass} aria-label="Main navigation">
          {links.map((link) => {
            const localizedHref = localizeHref(link.href, locale);
            const href = normalizePath(localizedHref);
            const isActive = href === '/' ? current === '/' : current.startsWith(href);

            return (
              <a
                class:list={[navLinkClass, { [navLinkActiveClass]: isActive }]}
                href={localizedHref}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noreferrer' : undefined}>
                {link.label}
              </a>
            );
          })}
        </nav>

        <div class="flex flex-wrap gap-2" aria-label="Locale switcher">
          {localeSwitchLinks.map((link) => (
            <a
              class:list={[localeLinkClass, { [localeLinkActiveClass]: link.locale === locale }]}
              href={link.href}
              hreflang={link.locale}>
              {link.label}
            </a>
          ))}
        </div>
      </div>
    )
  }

  {
    cta?.label && cta.href && (
      <a
        class={ctaClass}
        href={localizeHref(cta.href, locale)}
        target={cta.external ? '_blank' : undefined}
        rel={cta.external ? 'noreferrer' : undefined}>
        {cta.label}
      </a>
    )
  }
</header>
