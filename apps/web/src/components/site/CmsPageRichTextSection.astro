---
import type { CmsPageRichTextSection } from '@website-template/cms-sdk';
import { eyebrowClass, sectionShellClass, surfaceClass } from '@website-template/ui';

interface Props {
  section: CmsPageRichTextSection;
}

const { section } = Astro.props;
const articleClass = [
  surfaceClass,
  'space-y-4 p-6 md:p-8',
  section.width === 'narrow' ? 'max-w-3xl' : 'max-w-5xl',
  section.align === 'center' ? 'mx-auto text-center' : 'mr-auto',
];
---

<section class={sectionShellClass}>
  <article class:list={articleClass}>
    {section.eyebrow && <span class={eyebrowClass}>{section.eyebrow}</span>}
    {
      section.title && (
        <h2 class="text-3xl font-semibold tracking-tight text-zinc-950 sm:text-4xl">
          {section.title}
        </h2>
      )
    }
    {
      section.body && (
        <p class="whitespace-pre-line text-base leading-8 text-zinc-600">{section.body}</p>
      )
    }
  </article>
</section>
