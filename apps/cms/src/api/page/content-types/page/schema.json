{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Landing pages managed by Strapi."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "heroBadge": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "heroTitle": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "heroDescription": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "highlights": {
      "type": "json",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "primaryCta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "secondaryCta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "featureItems": {
      "type": "component",
      "repeatable": true,
      "component": "shared.feature-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "contentBlocks": {
      "type": "dynamiczone",
      "components": [
        "sections.rich-text",
        "sections.feature-grid",
        "sections.pricing-grid",
        "sections.logo-cloud",
        "sections.testimonials",
        "sections.faq",
        "sections.cta-band",
        "sections.contact-form"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
