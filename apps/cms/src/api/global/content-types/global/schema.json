    "footerLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link"
    },
    "primaryCta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link"
    },
    "defaultSeo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
