{
  "kind": "singleType",
  "collectionName": "globals",
  "info": {
    "singularName": "global",
    "pluralName": "globals",
    "displayName": "Global Settings",
    "description": "Site-wide branding, navigation and SEO for the landing page template."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "siteDescription": {
      "type": "text",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "navigationLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "footerLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "primaryCta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "defaultSeo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
