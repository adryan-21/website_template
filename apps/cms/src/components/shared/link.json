{
  "collectionName": "components_shared_links",
  "info": {
    "displayName": "Link",
    "description": "Reusable CTA, navigation and footer link."
  },
  "options": {},
  "attributes": {
    "label": {
      "type": "string",
      "required": true
    },
    "href": {
      "type": "string",
