# Shared web configuration
WEB_PUBLIC_SITE_URL=http://localhost:4321
WEB_PUBLIC_CMS_URL=http://localhost:1338
WEB_CMS_API_URL=http://localhost:1338/api
WEB_CMS_API_TOKEN=replace-me

# Strapi server configuration
CMS_HOST=0.0.0.0
CMS_PORT=1338
CMS_APP_KEYS=replace-me-1,replace-me-2,replace-me-3,replace-me-4
CMS_API_TOKEN_SALT=replace-me
CMS_ADMIN_JWT_SECRET=replace-me
CMS_TRANSFER_TOKEN_SALT=replace-me
CMS_JWT_SECRET=replace-me

# Strapi database configuration
CMS_DATABASE_CLIENT=postgres
CMS_DATABASE_HOST=127.0.0.1
CMS_DATABASE_PORT=5432
CMS_DATABASE_NAME=website_template
CMS_DATABASE_USERNAME=strapi
CMS_DATABASE_PASSWORD=strapi
CMS_DATABASE_SSL=false

# PostgreSQL container configuration
POSTGRES_DB=website_template
POSTGRES_USER=strapi
POSTGRES_PASSWORD=strapi
